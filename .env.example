# Site
# NEXT_PUBLIC_SITE_URL=https://sdreamclouds.com

# Contact form — required for production (Vercel: Project Settings → Environment Variables)
# Gmail App Password: https://myaccount.google.com/apppasswords
CONTACT_TO=sdreamclouds@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=sdreamclouds@gmail.com
SMTP_PASS=your-16-char-app-password
# Optional
# SMTP_FROM="Sdreamclouds Contact" <sdreamclouds@gmail.com>

# Local development: copy to .env.local
# Production (Vercel): add the same variables in the dashboard, then redeploy
